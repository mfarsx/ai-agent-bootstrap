{
  "name": "ai-agent-bootstrap",
  "version": "1.1.1",
  "description": "Bootstrap AI-agent-ready development environments with provider-specific templates (cline, cursor, openclaw, windsurf, claude-code).",
  "main": "src/index.js",
  "bin": {
    "ai-bootstrap": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node tests/run-tests.js",
    "init": "node bin/cli.js init",
    "status": "node bin/cli.js status",
    "pack:dry-run": "npm pack --dry-run",
    "publish:check": "npm run test && npm run pack:dry-run",
    "prepublishOnly": "npm run publish:check"
  },
  "keywords": [
    "ai",
    "agent",
    "bootstrap",
    "cline",
    "cursor",
    "openclaw",
    "windsurf",
    "claude-code",
    "memory-bank",
    "dev-tools",
    "cli",
    "scaffold",
    "ai-coding",
    "workflow"
  ],
  "author": "mfarsx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfarsx/ai-agent-bootstrap"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^8.2.6",
    "fs-extra": "^11.2.0"
  }
}
