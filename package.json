{
  "name": "ai-agent-bootstrap",
  "version": "1.3.0",
  "description": "CLI to scaffold AI-agent context, rules, and memory files for Cline, Cursor, OpenClaw, Windsurf, and Claude Code.",
  "main": "src/index.js",
  "bin": {
    "ai-agent-bootstrap": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node tests/run-tests.js",
    "init": "node bin/cli.js init",
    "reset": "node bin/cli.js reset",
    "status": "node bin/cli.js status",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,md,json}\"",
    "pack:dry-run": "npm pack --dry-run",
    "publish:check": "npm run lint && npm run test && npm run pack:dry-run",
    "prepublishOnly": "npm run publish:check"
  },
  "keywords": [
    "ai-agent",
    "ai-cli",
    "bootstrap",
    "project-scaffolding",
    "context-engineering",
    "memory-bank",
    "developer-tooling",
    "cline",
    "cursor",
    "openclaw",
    "windsurf",
    "claude-code",
    "workflow",
    "cli"
  ],
  "author": "mfarsx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfarsx/ai-agent-bootstrap"
  },
  "homepage": "https://github.com/mfarsx/ai-agent-bootstrap#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "diff": "^5.2.2",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3"
  }
}
